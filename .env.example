# LLM provider credentials. Configure at least one. Order is failover priority.
# Cerebras   -> https://cloud.cerebras.ai/   (Llama 3.3 70B, ~2600 tok/s, 1M tokens/day free)
# Groq       -> https://console.groq.com/    (Llama 3.3 70B Versatile, 14.4k req/day free)
# OpenRouter -> https://openrouter.ai/keys   (Llama 3.3 70B free tier, last-resort failover)
CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides
LLM_PRIMARY_PROVIDER=cerebras
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096